{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Whisper",
  "version": "0.1.0",
  "identifier": "com.chrishildreth.localwhisper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Local Whisper",
        "width": 820,
        "height": 720,
        "minWidth": 480,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "indicator",
        "url": "index.html?indicator=1",
        "width": 320,
        "height": 160,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
